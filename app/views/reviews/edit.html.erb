<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-md-8">
      
      <div class="text-center mb-4">
        <h2 class="fw-bold">レビューの編集</h2>
      </div>

      <div class="card shadow-sm">
        <div class="card-body p-4">
          
          <%= form_with model: @review, local: true do |f| %>
            
            <%# エラー表示 %>
            <% if @review.errors.any? %>
              <div class="alert alert-danger">
                <ul class="mb-0">
                  <% @review.errors.full_messages.each do |msg| %>
                    <li><%= msg %></li>
                  <% end %>
                </ul>
              </div>
            <% end %>

            <%# タイトル %>
            <div class="mb-3">
              <%= f.label :title, "タイトル", class: "form-label fw-bold" %>
              <%= f.text_field :title, class: "form-control", placeholder: "タイトルを入力" %>
            </div>

            <%# 本文 %>
            <div class="mb-4">
              <%= f.label :body, "レビュー本文", class: "form-label fw-bold" %>
              <%= f.text_area :body, rows: 10, class: "form-control", placeholder: "本文を入力" %>
            </div>

            <div class="row mb-4">
              <%# カテゴリ（日本語リストを使用） %>
              <div class="col-md-6 mb-3 mb-md-0">
                <%= f.label :category, "カテゴリ", class: "form-label fw-bold" %>
                <%= f.select :category, Review.category_options.map { |name, key| [name, Review.categories[key]] }, { include_blank: "選択してください" }, class: "form-select" %>
              </div>

              <%# 星評価 %>
              <div class="col-md-6">
                <%= f.label :rating, "評価", class: "form-label fw-bold" %>
                <%= f.select :rating, [["★★★★★ (5)", 5], ["★★★★ (4)", 4], ["★★★ (3)", 3], ["★★ (2)", 2], ["★ (1)", 1]], {}, class: "form-select text-warning fw-bold" %>
              </div>
            </div>

            <%# 公開設定 %>
            <div class="mb-4 form-check form-switch p-3 bg-light border rounded">
              <div class="ms-4">
                <%= f.check_box :is_published, class: "form-check-input", id: "publishSwitch" %>
                <%= f.label :is_published, "みんなのレビューに公開する", class: "form-check-label fw-bold", for: "publishSwitch" %>
              </div>
            </div>

            <%# ボタンエリア %>
            <div class="d-grid gap-2">
              <%= f.submit "更新する", class: "btn btn-success btn-lg fw-bold" %>
              <%= link_to "詳細に戻る", review_path(@review), class: "btn btn-outline-secondary" %>
            </div>

            <%# 削除ボタン（右寄せ） %>
            <div class="mt-4 text-end">
              <%= link_to "このレビューを削除する", review_path(@review), data: { turbo_method: :delete, turbo_confirm: "本当に削除しますか？" }, class: "text-danger small text-decoration-none" %>
            </div>

          <% end %>
        </div>
      </div>

    </div>
  </div>
</div>
<div class="row justify-content-center">
  <div class="col-md-8">
    
    <%# 戻るリンク %>
    <div class="mb-3">
      <%= link_to "← 一覧に戻る", reviews_path, class: "text-decoration-none" %>
    </div>

    <div class="card shadow-sm mb-4">
      <div class="card-body">
        
        <%# ヘッダー部分（タイトル・投稿者・評価） %>
        <h1 class="card-title fw-bold mb-3"><%= @review.title %></h1>
        
        <div class="d-flex justify-content-between align-items-center text-muted mb-4">
          <%# 左側：ユーザー情報と日付 %>
          <div>
            <i class="fas fa-user-circle"></i> <%= @review.user.name %> さん
            <span class="mx-2">|</span>
            <%= @review.created_at.strftime('%Y/%m/%d') %>
          </div>

          <%# 右側：いいねボタン ＆ 星評価 %>
          <div class="d-flex align-items-center gap-3">
            <%# ▼▼▼ ：いいねボタン（非同期） ▼▼▼ %>
            <%= render "reviews/favorites/btn", review: @review %>

            <%# 星の数だけ★を表示する簡易的な書き方 %>
            <div class="fs-5 text-warning">
              <%= "★" * (@review.rating || 0) %>
            </div>
          </div>
        </div>

        <%# 感情の熱量プログレスバー %>
        <%# ========================================== %>
        <% if @review.emotion_score.present? %>
          <div class="mb-4 p-3 bg-danger bg-opacity-10 rounded border border-danger border-opacity-25">
            <div class="d-flex justify-content-between align-items-center mb-2">
              <span class="fw-bold text-danger"><i class="fas fa-fire-alt me-2"></i>AIが分析した「感情の熱量」</span>
              <span class="fw-bold fs-5 text-danger"><%= (@review.emotion_score * 10).round %>%</span>
            </div>
            <div class="progress shadow-sm" style="height: 12px;">
              <%# widthでゲージの長さをパーセンテージ指定しています %>
              <div class="progress-bar bg-danger progress-bar-striped progress-bar-animated" role="progressbar" 
                   style="width: <%= (@review.emotion_score * 10).round %>%;" 
                   aria-valuenow="<%= (@review.emotion_score * 10).round %>" aria-valuemin="0" aria-valuemax="100">
              </div>
            </div>
          </div>
        <% end %>


        <hr>

        <%# 本文 %>
        <div class="card-text lh-lg" style="white-space: pre-wrap;">
          <%= @review.body %>
        </div>

        <%# 元になった日記へのリンク（もしあれば） %>
        <% if @review.diary_id %>
          <div class="mt-5 p-3 bg-light rounded border">
            <small class="text-muted d-block mb-1">Source Diary</small>
            <i class="fas fa-book-open"></i> 
            <%= link_to "このレビューの元になった日記を見る", diary_path(@review.diary_id), class: "text-decoration-none" %>
          </div>
        <% end %>

      </div>
    </div>

    <%# 編集・削除ボタン（投稿者本人だけ） %>
    <% if current_user == @review.user %>
      <div class="d-flex justify-content-end gap-2">
        <%= link_to "編集する", edit_review_path(@review), class: "btn btn-outline-success" %>
        <%= button_to "削除する", review_path(@review), method: :delete, data: { turbo_confirm: "本当に削除しますか？" }, class: "btn btn-outline-danger" %>
      </div>
    <% end %>

  </div>
</div>
<div class="row justify-content-center">
  <div class="col-md-8">
    
    <%# 戻るリンク %>
    <div class="mb-3">
      <%= link_to "← 一覧に戻る", reviews_path, class: "text-decoration-none" %>
    </div>

    <div class="card shadow-sm mb-4">
      <div class="card-body">
        
        <%# ヘッダー部分（タイトル・投稿者・評価） %>
        <h1 class="card-title fw-bold mb-3"><%= @review.title %></h1>
        
        <div class="d-flex justify-content-between align-items-center text-muted mb-4">
          <%# 左側：ユーザー情報と日付 %>
          <div>
            <i class="fas fa-user-circle"></i> <%= @review.user.name %> さん
            <span class="mx-2">|</span>
            <%= @review.created_at.strftime('%Y/%m/%d') %>
          </div>

          <%# 右側：いいねボタン ＆ 星評価 %>
          <div class="d-flex align-items-center gap-3">
            <%# ▼▼▼ ：いいねボタン（非同期） ▼▼▼ %>
            <%= render "reviews/favorites/btn", review: @review %>

            <%# 星の数だけ★を表示する簡易的な書き方 %>
            <div class="fs-5 text-warning">
              <%= "★" * (@review.rating || 0) %>
            </div>
          </div>
        </div>

        <%# 感情の熱量プログレスバー（権限による出し分け） %>
        <%# ========================================== %>
        <% if @review.emotion_score.present? %>
          <div class="mb-4 p-3 bg-light rounded border">
            
            <%# --- パターンA: 投稿者本人 または 管理者が見る場合（ダブルスコア表示） --- %>
            <% if current_user == @review.user || (current_user && current_user.admin?) %>
              <h6 class="fw-bold text-muted mb-3"><i class="fas fa-chart-bar me-2"></i>感情スコア分析（本人・管理者のみ表示）</h6>
              
              <%# 1. AIのスコア %>
              <div class="mb-3">
                <div class="d-flex justify-content-between align-items-center mb-1">
                  <span class="fw-bold text-danger small"><i class="fas fa-robot me-1"></i>AIが分析した熱量</span>
                  <span class="fw-bold text-danger"><%= (@review.emotion_score * 10).round %>%</span>
                </div>
                <div class="progress shadow-sm" style="height: 10px;">
                  <div class="progress-bar bg-danger" role="progressbar" style="width: <%= (@review.emotion_score * 10).round %>%;"></div>
                </div>
              </div>

              <%# 2. ユーザーのスコア（入力されている場合のみ表示） %>
              <% if @review.user_emotion_score.present? %>
                <div class="mb-2">
                  <div class="d-flex justify-content-between align-items-center mb-1">
                    <span class="fw-bold text-primary small"><i class="fas fa-user-edit me-1"></i>あなたが調整した熱量</span>
                    <span class="fw-bold text-primary"><%= (@review.user_emotion_score * 10).round %>%</span>
                  </div>
                  <div class="progress shadow-sm" style="height: 10px;">
                    <div class="progress-bar bg-primary" role="progressbar" style="width: <%= (@review.user_emotion_score * 10).round %>%;"></div>
                  </div>
                </div>
                
                <%# 🌟 ここが超貴重なデータ！AIとのギャップ（差分）表示 %>
                <div class="text-end mt-2">
                  <% gap = ((@review.user_emotion_score - @review.emotion_score) * 10).round %>
                  <span class="badge <%= gap > 0 ? 'bg-success' : (gap < 0 ? 'bg-warning text-dark' : 'bg-secondary') %>">
                    AIとのギャップ: <%= gap > 0 ? "+#{gap}" : gap %>%
                  </span>
                </div>
              <% end %>

            <%# --- パターンB: 一般ユーザーが見る場合（選んだ方だけ表示） --- %>
            <% else %>
              <% 
                is_user_score = (@review.user_score? && @review.user_emotion_score.present?)
                display_score = is_user_score ? @review.user_emotion_score : @review.emotion_score 
                color_class = is_user_score ? "primary" : "danger"
                icon_class = is_user_score ? "fa-user-edit" : "fa-robot"
                label_text = is_user_score ? "レビューの熱量" : "AIが分析した熱量"
              %>
              <div class="d-flex justify-content-between align-items-center mb-2">
                <span class="fw-bold text-<%= color_class %>"><i class="fas <%= icon_class %> me-2"></i><%= label_text %></span>
                <span class="fw-bold fs-5 text-<%= color_class %>"><%= (display_score * 10).round %>%</span>
              </div>
              <div class="progress shadow-sm" style="height: 12px;">
                <div class="progress-bar bg-<%= color_class %> progress-bar-striped progress-bar-animated" role="progressbar" style="width: <%= (display_score * 10).round %>%;"></div>
              </div>
            <% end %>

          </div>
        <% end %>


        <hr>

        <%# 本文 %>
        <div class="card-text lh-lg" style="white-space: pre-wrap;">
          <%= @review.body %>
        </div>

        <%# 元になった日記へのリンク（もしあれば） %>
        <% if @review.diary_id %>
          <div class="mt-5 p-3 bg-light rounded border">
            <small class="text-muted d-block mb-1">Source Diary</small>
            <i class="fas fa-book-open"></i> 
            <%= link_to "このレビューの元になった日記を見る", diary_path(@review.diary_id), class: "text-decoration-none" %>
          </div>
        <% end %>

      </div>
    </div>

    <%# 編集・削除ボタン（投稿者本人だけ） %>
    <% if current_user == @review.user %>
      <div class="d-flex justify-content-end gap-2">
        <%= link_to "編集する", edit_review_path(@review), class: "btn btn-outline-success" %>
        <%= button_to "削除する", review_path(@review), method: :delete, data: { turbo_confirm: "本当に削除しますか？" }, class: "btn btn-outline-danger" %>
      </div>
    <% end %>

  </div>
</div>
<div class="row">
  <div class="col-12 mb-4">
    <h2 class="fw-bold">みんなのレビュー</h2>
    <p class="text-muted">AIと共に生まれた、新しい発見。</p>
  </div>
</div>

<%# --- 検索フォーム --- %>
  <div class="card shadow-sm mb-5 border-0 bg-light">
    <div class="card-body p-4">
      <%= search_form_for @q, url: reviews_path, class: "row g-3 align-items-end" do |f| %>
        
        <%# キーワード検索（タイトル または 本文） %>
        <div class="col-md-5">
          <%= f.label :title_or_body_cont, "キーワード", class: "form-label fw-bold text-muted small" %>
          <%= f.search_field :title_or_body_cont, class: "form-control", placeholder: "タイトルや本文で検索..." %>
        </div>

        <%# カテゴリ検索（以前作った日本語リストを使用） %>
        <div class="col-md-4">
          <%= f.label :category_eq, "カテゴリ", class: "form-label fw-bold text-muted small" %>
          <%# モデルの定義を使って、'movie' を '2' に変換して送るようにします %>
          <%= f.select :category_eq, Review.category_options.map { |name, key| [name, Review.categories[key]] }, { include_blank: "すべてのカテゴリ" }, class: "form-select" %>
        </div>

        <%# 検索ボタン %>
        <div class="col-md-3">
          <%= f.button type: :submit, class: "btn btn-primary w-100 fw-bold" do %>
            <i class="fas fa-search me-1"></i> 検索する
          <% end %>
        </div>
        
      <% end %>
    </div>
  </div>

<div class="row">
  <% @reviews.each do |review| %>
    <div class="col-md-6 mb-4">
      <div class="card h-100 shadow-sm hover-shadow">
        <div class="card-body">
          <div class="d-flex justify-content-between mb-2">
            <span class="badge bg-secondary">カテゴリ: <%= review.category %></span>
            <span class="text-warning"><%= "★" * (review.rating || 0) %></span>
          </div>
          
          <h5 class="card-title fw-bold">
            <%= link_to review.title, review_path(review), class: "text-decoration-none text-dark stretched-link" %>
          </h5>
          
          <%# 本文の最初の50文字だけ表示 %>
          <p class="card-text text-muted">
            <%= truncate(review.body, length: 50) %>
          </p>
        </div>
        <div class="card-footer bg-white border-top-0 d-flex justify-content-between align-items-center">
          <small class="text-muted">
            <i class="fas fa-user"></i> <%= review.user.name %>
          </small>
          <small class="text-muted">
            <%= time_ago_in_words(review.created_at) %>前
          </small>
        </div>
      </div>
    </div>
  <% end %>
</div>
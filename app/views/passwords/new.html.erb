<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-md-6 col-lg-5">
      
      <div class="card shadow-sm border-0">
        <div class="card-body p-4">
          
          <%# タイトル %>
          <div class="text-center mb-4">
            <h2 class="fw-bold">パスワード再設定</h2>
            <p class="text-muted small">
              登録したメールアドレスを入力してください。<br>
              パスワード再設定用のリンクをお送りします。
            </p>
          </div>

          <%# フラッシュメッセージ（エラー時） %>
          <% if flash[:alert] %>
            <div class="alert alert-danger text-center small mb-3">
              <%= flash[:alert] %>
            </div>
          <% end %>

          <%# --- フォーム --- %>
          <%= form_with url: passwords_path, local: true do |f| %>
            
            <%# メールアドレス %>
            <div class="mb-4">
              <%= f.label :email_address, "メールアドレス", class: "form-label fw-bold" %>
              <%= f.email_field :email_address, class: "form-control", placeholder: "name@example.com", autofocus: true, autocomplete: "email", required: true %>
            </div>

            <%# 送信ボタン %>
            <div class="d-grid gap-2 mb-4">
              <%= f.submit "再設定メールを送信", class: "btn btn-primary btn-lg fw-bold" %>
            </div>
          <% end %>

          <hr class="my-4 text-secondary opacity-25">

          <%# --- 戻るリンク --- %>
          <div class="text-center">
            <%= link_to "ログイン画面に戻る", new_session_path, class: "text-decoration-none text-secondary" %>
          </div>

        </div>
      </div>

    </div>
  </div>
</div>
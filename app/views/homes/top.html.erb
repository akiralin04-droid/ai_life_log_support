<% if current_user %>
  <%# ========================================== %>
  <%# ログイン時（ダッシュボード）の表示 %>
  <%# ========================================== %>
  <div class="container py-5">
    <h2 class="mb-4 fw-bold">ダッシュボード</h2>
    <p class="fs-5 text-muted mb-5">何を記録しますか？</p>
    
    <%# ダッシュボードのメニュー（カード形式で横並び） %>
    <div class="row g-4 mb-5">
      <%# マイページへ %>
      <div class="col-md-4">
        <div class="card h-100 shadow-sm border-0 bg-light">
          <div class="card-body text-center p-4">
            <h5 class="card-title fw-bold">👤 マイページ</h5>
            <p class="card-text text-muted small mt-2">過去の記録や設定を確認します。</p>
            <%= link_to "マイページへ", mypage_path, class: "btn btn-outline-primary mt-2" %>
          </div>
        </div>
      </div>

      <%# 日記を書く %>
      <div class="col-md-4">
        <div class="card h-100 shadow-sm border-0" style="background-color: #f0f8ff;">
          <div class="card-body text-center p-4">
            <h5 class="card-title fw-bold">📖 日記を書く</h5>
            <p class="card-text text-muted small mt-2">今日のできごとや感情を記録しましょう。</p>
            <%= link_to "日記を書く", new_diary_path, class: "btn btn-primary mt-2" %>
          </div>
        </div>
      </div>

      <%# レビューを書く %>
      <div class="col-md-4">
        <div class="card h-100 shadow-sm border-0" style="background-color: #f5fffa;">
          <div class="card-body text-center p-4">
            <h5 class="card-title fw-bold">✨ レビューを書く</h5>
            <p class="card-text text-muted small mt-2">AIの分析から記事を作成・共有します。</p>
            <%# 🌟 修正：直接チャット画面に飛ぶボタンに変更 %>
            <div class="d-grid mt-3">
              <%= button_to "レビューを書く", ai_interviews_path, method: :post, class: "btn btn-success w-100 shadow-sm" %>
            </div>
          </div>
        </div>
      </div>
      
    </div>

    <%# お知らせ・キャンペーン情報エリア（動的化） %>
    <div class="p-4 mb-4 bg-white rounded-3 shadow-sm border">
      <h4 class="fw-bold fs-5 border-bottom pb-2 mb-3">📢 開催中のキャンペーン</h4>
      
      <%# キャンペーンが1件以上ある場合 %>
      <% if @active_campaigns.any? %>
        <div class="list-group list-group-flush mb-0">
          <%# 取得したキャンペーンを1つずつ取り出して表示する（ループ） %>
          <% @active_campaigns.each do |campaign| %>
            <%# クリックすると、一般ユーザー向けのキャンペーン詳細画面に飛ぶリンク %>
            <%= link_to campaign_path(campaign), class: "list-group-item list-group-item-action py-3" do %>
              <div class="d-flex w-100 justify-content-between align-items-center mb-1">
                <h6 class="mb-0 fw-bold text-primary">
                  <span class="badge bg-warning text-dark me-2">キャンペーン</span>
                  <%= campaign.title %>
                </h6>
                <small class="text-muted">
                  <% if campaign.end_date %>
                    <%= campaign.end_date.strftime("%m/%d %H:%M") %> まで
                  <% end %>
                </small>
              </div>
              <p class="mb-1 text-muted small"><i class="fas fa-building me-1"></i> <%= campaign.company_name %></p>
              <p class="mb-0 text-muted small text-truncate"><%= campaign.description %></p>
            <% end %>
          <% end %>
        </div>
      <% else %>
        <%# キャンペーンが1件もない場合の表示 %>
        <p class="text-muted mb-0 py-2">現在開催中のキャンペーンはありません。</p>
      <% end %>
    </div>
  </div>
  
  <%# 初回オンボーディング（チュートリアル）モーダル %>
  <%# ========================================== %>
  <% unless current_user.onboarding_completed %>
    <%# data-bs-backdrop="static" で、外側をクリックしても閉じないようにし、確実に読んでもらいます %>
    <div class="modal fade" id="onboardingModal" tabindex="-1" data-bs-backdrop="static" data-bs-keyboard="false" aria-hidden="true">
      <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content border-0 shadow-lg rounded-4 overflow-hidden">
          
          <div class="modal-body p-0">
            <%# Bootstrapのカルーセル（スライド）機能を使用 %>
            <div id="onboardingCarousel" class="carousel slide" data-bs-ride="false" data-bs-wrap="false">
              
              <%# スライドの下部にあるドットのインジケーター %>
              <div class="carousel-indicators mb-2">
                <button type="button" data-bs-target="#onboardingCarousel" data-bs-slide-to="0" class="active bg-primary" aria-current="true"></button>
                <button type="button" data-bs-target="#onboardingCarousel" data-bs-slide-to="1" class="bg-primary"></button>
                <button type="button" data-bs-target="#onboardingCarousel" data-bs-slide-to="2" class="bg-primary"></button>
              </div>

              <div class="carousel-inner text-center">
                <%# スライド1：ウェルカム %>
                <div class="carousel-item active p-5">
                  <div class="mb-4"><i class="fas fa-book-open text-primary" style="font-size: 4rem;"></i></div>
                  <h3 class="fw-bold mb-3">AI Life Log Support へようこそ！</h3>
                  <p class="text-muted fs-5 mb-5">ここは、あなたの何気ない日々の記録を<br>AIが価値ある「レビュー」へと変える場所です。</p>
                  <button class="btn btn-outline-primary rounded-pill px-4" data-bs-target="#onboardingCarousel" data-bs-slide="next">次へ <i class="fas fa-chevron-right ms-1"></i></button>
                </div>

                <%# スライド2：音声入力の魅力 %>
                <div class="carousel-item p-5">
                  <div class="mb-4"><i class="fas fa-microphone-alt text-danger" style="font-size: 4rem;"></i></div>
                  <h3 class="fw-bold mb-3">声で手軽に記録（無限推敲）</h3>
                  <p class="text-muted fs-5 mb-5">タイピングは不要です。マイクに向かって独り言を話すだけで、<br>AIが綺麗に文章を整え、対話しながら深掘りしてくれます。</p>
                  <div class="d-flex justify-content-center gap-3">
                    <button class="btn btn-light rounded-pill px-4" data-bs-target="#onboardingCarousel" data-bs-slide="prev"><i class="fas fa-chevron-left me-1"></i> 戻る</button>
                    <button class="btn btn-outline-primary rounded-pill px-4" data-bs-target="#onboardingCarousel" data-bs-slide="next">次へ <i class="fas fa-chevron-right ms-1"></i></button>
                  </div>
                </div>

                <%# スライド3：完了して始める %>
                <div class="carousel-item p-5">
                  <div class="mb-4"><i class="fas fa-rocket text-success" style="font-size: 4rem;"></i></div>
                  <h3 class="fw-bold mb-3">さあ、始めましょう！</h3>
                  <p class="text-muted fs-5 mb-4">キャンペーンに参加して企業の課題を解決したり、<br>自分の心の変化（感情スコア）を分析したりできます。</p>
                  <div class="d-flex justify-content-center gap-3 mt-4">
                    <button class="btn btn-light rounded-pill px-4" data-bs-target="#onboardingCarousel" data-bs-slide="prev"><i class="fas fa-chevron-left me-1"></i> 戻る</button>
                    <%# ここでコントローラーへ完了のリクエストを送信する %>
                    <%= link_to "さっそく始める", onboarding_path, data: { turbo_method: :patch }, class: "btn btn-primary rounded-pill px-5 shadow-sm fw-bold" %>
                  </div>
                </div>
              </div>
              
            </div>
          </div>
          
        </div>
      </div>
    </div>

    <%# 画面が読み込まれた時に、自動でモーダルを起動するJavaScript %>
    <script>
      document.addEventListener("turbo:load", function() {
        var onboardingModalEl = document.getElementById('onboardingModal');
        if (onboardingModalEl) {
          var myModal = new bootstrap.Modal(onboardingModalEl);
          myModal.show();
        }
      });
    </script>
  <% end %>

<% else %>
  <%# ========================================== %>
  <%# 未ログイン時（ランディングページ）の表示 %>
  <%# ========================================== %>
  <div class="p-5 mb-4 bg-light rounded-3 text-center">
    <div class="container-fluid py-5">
      
      <h1 class="display-5 fw-bold mb-3">AI Life Log Support</h1>
      
      <p class="col-lg-10 fs-4 mx-auto text-break">
        日々の記録から、価値ある「レビュー」を。<br>
        AIがあなたの「日記」を分析し、<span class="d-inline-block">共有できる「レビュー」を生成します。</span>
      </p>
      
      <div class="mt-4 gap-3 d-sm-flex justify-content-sm-center">
        <%= button_to "ゲストログイン（閲覧用）", session_guest_login_path, class: "btn btn-warning btn-lg px-4 gap-3" %>
        
        <div class="mt-3 mt-sm-0">
          <%= link_to "新規登録して始める", new_registration_path, class: "btn btn-primary btn-lg px-4 gap-3" %>
        </div>
      </div>
    </div>
  </div>
<% end %>
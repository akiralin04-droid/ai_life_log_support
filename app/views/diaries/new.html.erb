<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-md-8">
      
      <div class="text-center mb-5">
        <h2 class="fw-bold">今日の日記を書く</h2>
        <p class="text-muted">
          まずは今日のスケジュールや出来事を簡単に教えてください。<br>
          AIがそれを読み込み、あなたにぴったりの質問を投げかけます！
        </p>
      </div>

      <div class="card shadow-sm border-0">
        <div class="card-body p-4">
          
          <%= form_with model: @diary, local: true do |f| %>
            
            <div class="mb-4">
              <%= f.label :schedule, "📅 今日の予定・出来事（箇条書きでOK！）", class: "form-label fw-bold" %>
              <%# 最初から「朝・昼・夕方・夜」の文字を入れておく %>
              <%= f.text_area :schedule, rows: 6, class: "form-control bg-light", value: @diary.schedule || "朝：\n昼：\n夕方：\n夜：" %>
            </div>

            <%# 日記本文(content)は、この後AIが自動で書くため、ここでは隠しフィールド(空)にしておきます %>
            <%= f.hidden_field :content, value: "" %>

            <div class="d-grid gap-2">
              <%= f.submit "AIに深掘りしてもらう ✨", class: "btn btn-primary btn-lg fw-bold" %>
              <%= link_to "キャンセルして戻る", mypage_path, class: "btn btn-outline-secondary" %>
            </div>
            
          <% end %>

        </div>
      </div>

    </div>
  </div>
</div>
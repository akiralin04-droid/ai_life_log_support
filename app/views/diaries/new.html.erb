<%# 画面の中央に配置 %>
<div class="container py-5"> <%# 上下に余白を追加 %>
  <div class="row justify-content-center">
    <div class="col-md-8">
      
      <%# タイトル %>
      <div class="text-center mb-5"> <%# 下に余白を追加 %>
        <h2 class="fw-bold">今日の日記を書く</h2>
        <p class="text-muted">
          AIがあなたの記録をサポートします。<br>
          今日あったこと、感じたことを自由に書いてください。
        </p>
      </div>

      <%# エラーメッセージ表示エリア %>
      <% if @diary.errors.any? %>
        <div class="alert alert-danger">
          <ul class="mb-0">
            <% @diary.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <%# 入力フォーム %>
      <div class="card shadow-sm border-0"> <%# 枠線を消して影をつけるデザインに変更 %>
        <div class="card-body p-4"> <%# 内側の余白を広げる %>
          
          <%= form_with model: @diary, local: true do |f| %>
            
            <%# 日記本文の入力欄 %>
            <div class="mb-4">
              <%= f.label :content, "今の気持ちや出来事", class: "form-label fw-bold" %>
              <%# チャットボックスっぽく高さを確保 %>
              <%# bg-light で入力欄の背景を少しグレーにして見やすく %>
              <%= f.text_area :content, rows: 10, class: "form-control bg-light", placeholder: "例：今日は新しいカフェに行ってみた。コーヒーが美味しくて、読書が捗った..." %>
            </div>

            <%# 公開設定（トグルスイッチ風） %>
            <%# p-3 border rounded で囲んで目立たせる %>
            <div class="mb-4 form-check form-switch p-3 border rounded bg-light ms-0">
              <div class="ms-4"> <%# スイッチの位置調整 %>
                <%= f.check_box :is_published, class: "form-check-input", id: "publishSwitch" %>
                <%= f.label :is_published, "この日記を公開する（他の人に見せる）", class: "form-check-label fw-bold", for: "publishSwitch" %>
                <div class="form-text text-muted small">公開すると、みんなのレビュー一覧に表示される可能性があります。</div>
              </div>
            </div>

            <%# 送信ボタン %>
            <div class="d-grid gap-2">
              <%= f.submit "保存する", class: "btn btn-primary btn-lg fw-bold" %>
              
              <%# ▼▼▼ 修正箇所: 戻るリンク先を変更 ▼▼▼ %>
              <%# user_path(current_user) から mypage_path に変更しました %>
              <%# デザインもボタン風(btn-outline-secondary)に変更 %>
              <%= link_to "キャンセルして戻る", mypage_path, class: "btn btn-outline-secondary" %>
            </div>
          <% end %>
        </div>
      </div>

    </div>
  </div>
</div>
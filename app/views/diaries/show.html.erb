<%# コンテナで全体を囲み、上下に余白(py-5)を設定 %>
<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-md-8">

      <%# --- 日記の内容を表示するカード --- %>
      <div class="card shadow-sm mb-4">
        
        <%# カードのヘッダー：日付と公開ステータスを表示 %>
        <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
          <%# 日付 %>
          <span class="fw-bold text-muted">
            <i class="far fa-calendar-alt me-2"></i>
            <%= @diary.created_at.strftime('%Y年%m月%d日 %H:%M') %>
          </span>
          
          <%# 公開ステータスのバッジ表示 %>
          <% if @diary.is_published %>
            <span class="badge bg-success">公開中</span>
          <% else %>
            <span class="badge bg-secondary">非公開</span>
          <% end %>
        </div>

        <%# カードのボディ：日記の本文を表示 %>
        <div class="card-body p-4">
          <%# simple_format だと改行が多くなりすぎることがあるため、styleで調整 %>
          <%# white-space: pre-wrap は改行コードをそのまま改行として表示するCSSです %>
          <div class="card-text" style="white-space: pre-wrap; line-height: 1.8; color: #4b5563;">
            <%= @diary.content %>
          </div>
        </div>

        <%# カードのフッター：操作ボタン %>
        <div class="card-footer bg-white py-3">
          <div class="d-flex justify-content-end gap-2">
          <%# ▼▼▼ 追加: 編集ボタン ▼▼▼ %>
            <%= link_to "編集する", edit_diary_path(@diary), class: "btn btn-outline-success btn-sm" %>
            <%# 削除ボタン：turbo_method: :delete でDELETEリクエストを送信 %>
            <%# turbo_confirm で削除前の確認ダイアログを表示 %>
            <%= link_to "削除する", diary_path(@diary), data: { turbo_method: :delete, turbo_confirm: "本当に削除しますか？" }, class: "btn btn-outline-danger btn-sm" %>
            
            <%# マイページへ戻るボタン %>
            <%= link_to "マイページへ", mypage_path, class: "btn btn-outline-secondary btn-sm" %>
          </div>
        </div>
      </div>

      <%# --- AI分析レポートエリア --- %>
      <div class="card border-info border-opacity-25 bg-info bg-opacity-10 mb-4">
        <div class="card-body text-center py-4">
          <h5 class="text-info fw-bold mb-3"><i class="fas fa-robot"></i> AI分析レポート</h5>
          
          <% if @diary.ai_response.present? %>
            <div class="text-start d-inline-block text-dark mb-3" style="max-width: 100%;">
              <i class="fas fa-quote-left text-info opacity-50 fa-2x float-start me-2"></i>
              <div style="font-size: 1.05rem; line-height: 1.8;">
                <%= simple_format(@diary.ai_response) %>
              </div>
            </div>
          <% else %>
            <div class="py-3">
              <div class="spinner-border text-info mb-2" role="status">
                <span class="visually-hidden">Loading...</span>
              </div>
              <p class="text-muted mb-0">AIが分析中です...<br><small>（リロードすると表示される場合があります）</small></p>
            </div>
          <% end %>
        </div>
      </div>

      <%# ▼▼▼ レビュー作成への導線を、AI分析の外（下）に出しました！ ▼▼▼ %>
      <div class="card shadow-sm border-0 bg-light">
        <div class="card-body text-center p-4">
          <% if @diary.review %>
            <p class="text-muted mb-2">この日記はすでにレビュー済みです。</p>
            <%= link_to "レビューを見る", review_path(@diary.review), class: "btn btn-outline-info" %>
          <% else %>
            <p class="fw-bold text-dark mb-2">この日記をもとに、AIと対話してレビューを作成しますか？</p>
            <p class="small text-muted mb-3">対話しながら感情を深掘りし、魅力的なレビューに仕上げましょう！</p>
            
            <%# ここも data: { turbo_method: :post } で直接チャット画面へ！ %>
            <%= link_to ai_interviews_path(diary_id: @diary.id), data: { turbo_method: :post }, class: "btn btn-success fw-bold text-white px-4 shadow-sm rounded-pill" do %>
              <i class="fas fa-magic me-1"></i> AIインタビューを開始する 💬✨
            <% end %>
          <% end %>
        </div>
      </div>

      
    </div>
  </div>
</div>
<div class="row justify-content-center">
  <div class="col-md-8">
    
    <%# ：今のチャットが「日記関連（新規 or 推敲）」かを判定 %>
    <% is_diary_mode = !@ai_interview.review_creation? %>

    <%# ヘッダー部分 %>
    <div class="d-flex justify-content-between align-items-center mb-3">
      <h3 class="fw-bold mb-0"><i class="fas fa-robot text-primary me-2"></i>AIインタビュー</h3>
      
      <div class="d-flex gap-2">
        <% if is_diary_mode %>
          <%= link_to "一覧に戻る", mypage_path, class: "btn btn-outline-secondary btn-sm" %>
        <% else %>
          <%= link_to new_review_path, class: "btn btn-outline-success btn-sm" do %>
            <i class="fas fa-pen me-1"></i> AIを使わず自分で書く
          <% end %>
          <%= link_to "一覧に戻る", reviews_path, class: "btn btn-outline-secondary btn-sm" %>
        <% end %>
      </div>
    </div>

    <%# チャット履歴エリア %>
    <div class="card shadow-sm border-0 mb-4" style="background-color: #f8f9fa;">
      <div class="card-body p-4" style="height: 60vh; overflow-y: auto;" id="chat-messages">
        
        <% @messages.each do |message| %>
          <% if message.role == "user" %>
            <div class="d-flex justify-content-end mb-4">
              <div class="p-3 rounded-3 bg-success text-white shadow-sm" style="max-width: 75%; border-bottom-right-radius: 0 !important;">
                <%= simple_format(message.content, class: "mb-0") %>
              </div>
            </div>
          <% elsif message.role == "assistant" %>
            <div class="d-flex justify-content-start mb-4">
              <div class="me-2 mt-1">
                <i class="fas fa-robot fs-3 text-primary"></i>
              </div>
              <div class="p-3 rounded-3 bg-white border shadow-sm" style="max-width: 75%; border-top-left-radius: 0 !important;">
                <%= simple_format(message.content, class: "mb-0") %>
              </div>
            </div>
          <% end %>
        <% end %>
        
      </div>
    </div>

    <%# 🎙️ Stimulusコントローラーを紐づけたメッセージ送信フォーム %>
    <div class="card shadow-sm border-0" data-controller="voice-record">
      <div class="card-body p-3 p-md-4 d-flex flex-column gap-3">
        
        <%# 録音中のステータス表示 %>
        <p data-voice-record-target="status" class="text-danger fw-bold text-center d-none mb-0"></p>

        <%# チャット送信フォーム %>
        <%= form_with url: ai_interview_ai_messages_path(@ai_interview), local: true, class: "d-flex flex-column gap-3" do |f| %>
          
          <div class="d-flex flex-column flex-md-row align-items-stretch gap-3">
            <%# 🎙️ マイクボタン %>
            <div class="text-center">
              <button type="button" data-action="click->voice-record#toggle" data-voice-record-target="button" class="btn btn-outline-danger rounded-circle shadow-sm d-flex align-items-center justify-content-center mx-auto" style="width: 70px; height: 70px; flex-shrink: 0;">
                <span class="fs-2">🎤</span>
              </button>
              <div class="text-muted small mt-1 fw-bold">音声入力</div>
            </div>

            <%# テキスト入力欄 %>
            <div class="flex-grow-1">
              <%= f.text_area :content, data: { voice_record_target: "output" }, class: "form-control border border-2 bg-white fs-5 p-3 shadow-sm", rows: 7, placeholder: "マイクボタンを押して、AIの質問に自由に答えてください...", required: true %>
            </div>
          </div>

          <%# 🌟 送信・完了ボタン（テキストボックスの下に幅いっぱいでドドンと配置！） %>
          <div class="mt-2">
            <% if is_diary_mode %>
              <%= f.button class: "btn btn-warning fw-bold shadow-sm py-3 fs-5 text-dark w-100 rounded-pill", data: { disable_with: "AIが執筆中..." } do %>
                <i class="fas fa-magic me-2"></i>回答完了！AIに修正してもらう ✨
              <% end %>
            <% else %>
              <%= f.submit "送信", class: "btn btn-primary fw-bold shadow-sm py-3 fs-5 w-100 rounded-pill", data: { disable_with: "処理中..." } %>
            <% end %>
          </div>
        <% end %>

        <%# 🌟 レビューモードの時だけ、途中で終わらせる用の黄色いボタンを表示する %>
        <% unless is_diary_mode %>
          <hr class="m-0">
          <%= button_to finalize_ai_interview_path(@ai_interview), method: :post, class: "btn btn-warning w-100 fw-bold rounded-pill shadow-sm py-2 text-dark", data: { turbo: false } do %>
            <i class="fas fa-magic me-1"></i> 十分な情報が集まったので、レビューを生成する ✨
          <% end %>
        <% end %>

      </div>
    </div>

  </div>
</div>
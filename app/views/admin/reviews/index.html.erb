<div class="container py-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold m-0"><i class="fas fa-star me-2 text-success"></i> レビュー管理</h2>
    <%= link_to "ダッシュボードへ戻る", admin_path, class: "btn btn-outline-secondary" %>
  </div>

  <%# 検索フォーム（分割版） %>
  <div class="card shadow-sm border-0 mb-4 bg-light">
    <div class="card-body">
      <%= search_form_for @q, url: admin_reviews_path, class: "row g-3" do |f| %>
        <div class="col-md-5">
          <%= f.label :title_cont, "タイトルで検索", class: "form-label small fw-bold text-muted mb-1" %>
          <%= f.search_field :title_cont, class: "form-control", placeholder: "（例）最高の映画" %>
        </div>
        <div class="col-md-5">
          <%= f.label :body_cont, "本文で検索", class: "form-label small fw-bold text-muted mb-1" %>
          <%= f.search_field :body_cont, class: "form-control", placeholder: "レビューの内容" %>
        </div>
        <div class="col-md-2 d-flex align-items-end">
          <%= f.submit "検索する", class: "btn btn-primary w-100" %>
        </div>
      <% end %>
    </div>
  </div>

  <div class="card shadow-sm border-0">
    <div class="table-responsive">
      <table class="table table-hover align-middle mb-0">
        <thead class="table-light">
          <tr>
            <th><%= sort_link(@q, :id, "ID") %></th>
            <th><%= sort_link(@q, :is_published, "ステータス") %></th>
            <th><%= sort_link(@q, :title, "タイトル") %></th>
            <th>投稿者</th>
            <th><%= sort_link(@q, :created_at, "投稿日時") %></th>
            <th class="text-end">操作</th>
          </tr>
        </thead>
        <tbody>
          <% @reviews.each do |review| %>
            <tr>
              <td><%= review.id %></td>
              <td><span class="badge <%= review.is_published ? 'bg-success' : 'bg-secondary' %>"><%= review.is_published ? '公開中' : '非公開' %></span></td>
              <td class="fw-bold"><%= review.title %></td>
              <td><%= review.user&.name || review.user&.email_address || "不明" %></td>
              <td><%= review.created_at.strftime("%Y/%m/%d %H:%M") %></td>
              <td class="text-end">
                <%= link_to "詳細", admin_review_path(review), class: "btn btn-sm btn-outline-info" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
  <div class="d-flex justify-content-center mt-4"><%= paginate @reviews, theme: 'bootstrap-5' if defined?(Kaminari) %></div>
</div>
<div class="container py-4">
  <div class="row justify-content-center">
    <div class="col-md-8">
      <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold m-0">キャンペーン詳細</h2>
        <div>
          <%= link_to "編集", edit_admin_campaign_path(@campaign), class: "btn btn-primary" %>
          <%= link_to "一覧へ戻る", admin_campaigns_path, class: "btn btn-outline-secondary" %>
        </div>
      </div>

      <div class="card shadow-sm border-0 mb-4">
        <div class="card-body p-4">
          <div class="mb-4">
            <span class="badge <%= @campaign.is_active ? 'bg-success' : 'bg-secondary' %> mb-2">
              <%= @campaign.is_active ? '公開中' : '非公開' %>
            </span>
            <h3 class="fw-bold"><%= @campaign.title %></h3>
            <p class="text-muted"><i class="fas fa-building me-2"></i><%= @campaign.company_name %></p>
          </div>

          <table class="table table-bordered">
            <tbody>
              <tr>
                <th class="bg-light" style="width: 30%;">終了日時</th>
                <td><%= @campaign.end_date&.strftime("%Y年%m月%d日 %H:%M") || "未設定" %></td>
              </tr>
              <tr>
                <th class="bg-light">キャンペーン概要</th>
                <td><%= simple_format(@campaign.description) %></td>
              </tr>
              <tr>
                <th class="bg-light">AIへの指示<br><small class="text-muted">（プロンプト）</small></th>
                <td><pre class="bg-light p-3 rounded border"><%= @campaign.ai_prompt %></pre></td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</div>
<div class="container py-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold m-0">キャンペーン管理</h2>
    <%= link_to "＋ 新規作成", new_admin_campaign_path, class: "btn btn-primary" %>
  </div>

  <div class="card shadow-sm border-0">
    <div class="table-responsive">
      <table class="table table-hover align-middle mb-0">
        <thead class="table-light">
          <tr>
            <th>状態</th>
            <th>企業名</th>
            <th>タイトル</th>
            <th>終了日時</th>
            <th class="text-end">操作</th>
          </tr>
        </thead>
        <tbody>
          <% @campaigns.each do |campaign| %>
            <tr>
              <td>
                <% if campaign.is_active %>
                  <span class="badge bg-success">公開中</span>
                <% else %>
                  <span class="badge bg-secondary">非公開</span>
                <% end %>
              </td>
              <td><%= campaign.company_name %></td>
              <td class="fw-bold"><%= campaign.title %></td>
              <td><%= campaign.end_date&.strftime("%Y/%m/%d %H:%M") || "未設定" %></td>
              <td class="text-end">
                <%= link_to "詳細", admin_campaign_path(campaign), class: "btn btn-sm btn-outline-info" %>
                <%= link_to "編集", edit_admin_campaign_path(campaign), class: "btn btn-sm btn-outline-primary" %>
                <%= link_to "削除", admin_campaign_path(campaign), data: { turbo_method: :delete, turbo_confirm: "本当に削除しますか？" }, class: "btn btn-sm btn-outline-danger" %>
              </td>
            </tr>
          <% end %>
          <% if @campaigns.empty? %>
            <tr>
              <td colspan="5" class="text-center text-muted py-4">キャンペーンが登録されていません。</td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>
<div class="container py-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold m-0"><i class="fas fa-users me-2 text-primary"></i> ユーザー管理</h2>
    <%= link_to "ダッシュボードへ戻る", admin_path, class: "btn btn-outline-secondary" %>
  </div>

  <%# 検索フォーム（分割版） %>
  <div class="card shadow-sm border-0 mb-4 bg-light">
    <div class="card-body">
      <%= search_form_for @q, url: admin_users_path, class: "row g-3" do |f| %>
        <div class="col-md-5">
          <%= f.label :name_cont, "名前で検索", class: "form-label small fw-bold text-muted mb-1" %>
          <%= f.search_field :name_cont, class: "form-control", placeholder: "（例）山田太郎" %>
        </div>
        <div class="col-md-5">
          <%= f.label :email_address_cont, "メールアドレスで検索", class: "form-label small fw-bold text-muted mb-1" %>
          <%= f.search_field :email_address_cont, class: "form-control", placeholder: "（例）test@example.com" %>
        </div>
        <div class="col-md-2 d-flex align-items-end">
          <%= f.submit "検索する", class: "btn btn-primary w-100" %>
        </div>
      <% end %>
    </div>
  </div>

  <div class="card shadow-sm border-0">
    <div class="table-responsive">
      <table class="table table-hover align-middle mb-0">
        <thead class="table-light">
          <tr>
            <%# sort_link を使うと、見出しがクリックできる並び替えリンクになります！ %>
            <th><%= sort_link(@q, :id, "ID") %></th>
            <th>権限</th>
            <th><%= sort_link(@q, :is_active, "ステータス") %></th>
            <th><%= sort_link(@q, :name, "名前") %></th>
            <th><%= sort_link(@q, :email_address, "メールアドレス") %></th>
            <th><%= sort_link(@q, :created_at, "登録日時") %></th>
            <th class="text-end">操作</th>
          </tr>
        </thead>
        <tbody>
          <% @users.each do |user| %>
            <tr>
              <td><%= user.id %></td>
              <td>
                <span class="badge <%= user.admin? ? 'bg-danger' : 'bg-secondary' %>"><%= user.admin? ? '管理者' : '一般' %></span>
              </td>
              <td>
                <span class="badge <%= user.is_active ? 'bg-success' : 'bg-warning text-dark' %>"><%= user.is_active ? '有効' : '利用停止' %></span>
              </td>
              <td><%= user.name.presence || "未設定" %></td>
              <td><%= user.email_address %></td>
              <td><%= user.created_at.strftime("%Y/%m/%d %H:%M") %></td>
              <td class="text-end">
                <%= link_to "詳細", admin_user_path(user), class: "btn btn-sm btn-outline-info" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
  <div class="d-flex justify-content-center mt-4"><%= paginate @users, theme: 'bootstrap-5' if defined?(Kaminari) %></div>
</div>
<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-md-8">
      
      <%# ヘッダー %>
      <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold mb-0">ウィークリーAI分析レポート</h2>
        <%= link_to "マイページへ戻る", mypage_path, class: "btn btn-outline-secondary btn-sm" %>
      </div>

      <%# AIレポート本文のカード %>
      <div class="card shadow-sm border-info border-opacity-25 bg-info bg-opacity-10 mb-5">
        <div class="card-body p-4 p-md-5 text-dark" style="line-height: 1.8; font-size: 1.05rem;">
          <h5 class="text-info-emphasis fw-bold border-bottom border-info pb-3 mb-4">
            <i class="fas fa-magic me-2"></i> 
            <%= @weekly_report.start_date.strftime('%Y年%m月%d日') %> 〜 <%= @weekly_report.end_date.strftime('%m月%d日') %> の振り返り
          </h5>
          
          <%# AIの文章を綺麗に表示 %>
          <%= simple_format(@weekly_report.content) %>
        </div>
      </div>

      <%# このレポートに使われた日記一覧 %>
      <h5 class="fw-bold mb-3"><i class="fas fa-book me-2"></i> この分析に使われた日記 (<%= @diaries.count %>件)</h5>
      
      <div class="list-group shadow-sm mb-5">
        <% @diaries.each do |diary| %>
          <%= link_to diary_path(diary), data: { turbo_frame: "_top" }, class: "list-group-item list-group-item-action p-3" do %>
            <div class="d-flex w-100 justify-content-between align-items-center mb-1">
              <h6 class="mb-0 fw-bold"><%= diary.created_at.strftime('%m月%d日') %>の記録</h6>
              <small class="text-muted">詳細を見る <i class="fas fa-chevron-right ms-1"></i></small>
            </div>
            <%# プレビュー表示（本文かスケジュール） %>
            <p class="mb-0 text-secondary small text-truncate">
              <%= diary.content.presence || diary.schedule.presence || "記録あり" %>
            </p>
          <% end %>
        <% end %>
      </div>

      <%# レポートの削除ボタン（やり直したい時用） %>
      <div class="text-end border-top pt-4">
        <p class="text-muted small mb-2">※削除すると、使われていた日記は再び「未分析」の状態に戻ります。</p>
        <%= link_to weekly_report_path(@weekly_report), data: { turbo_method: :delete, turbo_confirm: "このレポートを削除してやり直しますか？" }, class: "btn btn-outline-danger" do %>
          <i class="fas fa-trash-alt me-1"></i> レポートを削除する
        <% end %>
      </div>

    </div>
  </div>
</div>
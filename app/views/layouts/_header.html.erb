<header>
  <%# navbar-dark: 文字を白く / bg-dark: 背景を黒く %>
  <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
    <div class="container">
      <%# ロゴ %>
      <%= link_to "AI Life Log", root_path, class: "navbar-brand fw-bold" %>
      
      <%# スマホ用メニューボタン %>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
        <span class="navbar-toggler-icon"></span>
      </button>
      
      <%# メニュー項目 %>
      <div class="collapse navbar-collapse" id="navbarNav">
        <ul class="navbar-nav ms-auto align-items-center">
          <% if current_user %>
            <%# ========================================== %>
            <%# 管理者の場合のみ表示する特別メニュー %>
            <%# ========================================== %>
            <% if current_user.admin? %>
              <li class="nav-item me-3">
                <%= link_to "👑 管理画面", admin_path, class: "nav-link text-warning fw-bold" %>
              </li>
            <% end %>

            <%# ========================================== %>
            <%# 通常のログイン時メニュー %>
            <%# ========================================== %>
            <li class="nav-item">
              <%= link_to "ホーム", root_path, class: "nav-link" %>
            </li>
            <li class="nav-item">
              <%= link_to "About", about_path, class: "nav-link" %>
            </li>
            <li class="nav-item">
              <%= link_to "日記を書く", new_diary_path, class: "nav-link" %>
            </li>
            
            <li class="nav-item">
              <%= link_to "レビューを書く", select_type_reviews_path, class: "nav-link" %>
            </li>

            <li class="nav-item">
              <%= link_to "みんなの日記", public_index_diaries_path, class: "nav-link" %>
            </li>
            <li class="nav-item">
              <%= link_to "みんなのレビュー", reviews_path, class: "nav-link" %>
            </li>
            <li class="nav-item">
              <%= link_to "マイページ", mypage_path, class: "nav-link" %>
            </li>
            <li class="nav-item ms-2">
              <%= button_to "ログアウト", session_path, method: :delete, class: "btn btn-outline-secondary btn-sm text-white-50" %>
            </li>
          <% else %>
            <%# ========================================== %>
            <%# 未ログイン時メニュー %>
            <%# ========================================== %>
            <li class="nav-item">
              <%= link_to "About", about_path, class: "nav-link" %>
            </li>
            <li class="nav-item">
              <%= link_to "みんなの日記", public_index_diaries_path, class: "nav-link" %>
            </li>
            <li class="nav-item">
              <%= link_to "みんなのレビュー", reviews_path, class: "nav-link" %>
            </li>
            <li class="nav-item">
              <%= link_to "新規登録", new_registration_path, class: "nav-link" %>
            </li>
            <li class="nav-item ms-2">
              <%= link_to "ログイン", new_session_path, class: "btn btn-outline-light btn-sm" %>
            </li>
          <% end %>
        </ul>
      </div>
    </div>
  </nav>
</header>
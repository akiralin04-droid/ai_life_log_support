<header>
  <%# navbar-dark: 文字を白く / bg-dark: 背景を黒く %>
  <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
    <div class="container">
      <%# ロゴ %>
      <%= link_to "AI Life Log", root_path, class: "navbar-brand fw-bold" %>
      
      <%# スマホ用メニューボタン %>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
        <span class="navbar-toggler-icon"></span>
      </button>
      
      <%# メニュー項目 %>
      <div class="collapse navbar-collapse" id="navbarNav">
        <ul class="navbar-nav ms-auto">
          <% if current_user %>
            <%# ログイン時 %>
            <li class="nav-item">
              <%= link_to "About", about_path, class: "nav-link" %>
            <li class="nav-item">
              <%= link_to "日記を書く", new_diary_path, class: "nav-link" %>
            </li>
            <li class="nav-item">
              <%= link_to "日記一覧", public_index_diaries_path, class: "nav-link" %>
            </li>
            <li class="nav-item">
              <%= link_to "レビュー一覧", reviews_path, class: "nav-link" %>
            </li>
            <li class="nav-item">
              <%= link_to "マイページ", mypage_path, class: "nav-link" %>
            </li>
            <li class="nav-item">
              <%= button_to "ログアウト", session_path, method: :delete, class: "nav-link btn btn-link text-decoration-none text-white-50" %>
            </li>
          <% else %>
            <%# 未ログイン時 %>
            <li class="nav-item">
              <%= link_to "About", about_path, class: "nav-link" %>
            </li>
            <li class="nav-item">
              <%= link_to "日記一覧", public_index_diaries_path, class: "nav-link" %>
            </li>
            <li class="nav-item">
              <%= link_to "レビュー一覧", reviews_path, class: "nav-link" %>
            </li>
            <li class="nav-item">
              <%= link_to "新規登録", new_registration_path, class: "nav-link" %>
            </li>
            <li class="nav-item">
              <%= link_to "ログイン", new_session_path, class: "nav-link" %>
            </li>
          <% end %>
        </ul>
      </div>
    </div>
  </nav>
</header>
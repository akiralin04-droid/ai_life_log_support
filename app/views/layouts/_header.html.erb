<header>
  <!-- ナビゲーションバーを作る箱（Bootstrapのデザイン） -->
  <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
    <div class="container">
      <!-- ロゴ（クリックするとトップページへ） -->
      <%= link_to "AI Life Log", root_path, class: "navbar-brand" %>
      
      <!-- ハンバーガーメニュー（スマホで見た時に出る三本線ボタン） -->
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
        <span class="navbar-toggler-icon"></span>
      </button>
      
      <!-- メニューの中身 -->
      <div class="collapse navbar-collapse" id="navbarNav">
        <!-- 右寄せにする設定 -->
        <ul class="navbar-nav ms-auto">

          <!-- ★ここが重要！ログイン状態による分岐 -->
          <% if current_user %>
            <%# --- ログインしている時 --- %>
            <li class="nav-item">
              <%= link_to "日記を書く", new_diary_path, class: "nav-link" %>
            </li>
            <li class="nav-item">
              <%= link_to "レビュー一覧", reviews_path, class: "nav-link" %>
            </li>
            <li class="nav-item">
              <%= link_to "マイページ", user_path(current_user), class: "nav-link" %>
            </li>
            <li class="nav-item">
              <!-- ログアウトは「データを消す」操作なので method: :delete が必要 -->
              <%= button_to "ログアウト", session_path, method: :delete, class: "nav-link btn btn-link text-decoration-none" %>
            </li>
          <% else %>
            <%# --- ログインしていない時 --- %>
            <li class="nav-item">
              <%= link_to "About", about_path, class: "nav-link" %>
            </li>
            <li class="nav-item">
              <%= link_to "レビュー一覧", reviews_path, class: "nav-link" %>
            </li>
            <li class="nav-item">
              <%= link_to "新規登録", new_registration_path, class: "nav-link" %>
            </li>
            <li class="nav-item">
              <%= link_to "ログイン", new_session_path, class: "nav-link" %>
            </li>
          <% end %>
        </ul>
      </div>
    </div>
  </nav>
</header>